<div id="LoginSection">
    <button id="createLobby">CREATE LOBBY</button>
    <button id="joinLobby">JOIN LOBBY</button>

    <div id="signupForm" hidden>
        <div>
            <form id="makeAccount">
                <h3>MAKE AN ACCOUNT :33333</h3>
                <input type="text" placeholder="Username" name="username"/>
                <input type="password" placeholder="Password" name="password"/>
                <input type="text" placeholder="Real Name" name="realName"/>
                <input type="email" placeholder="Email" name="email"/>
                <input type="color" placeholder="Favorate Color" name="favColor"/>
                <input type="month" placeholder="What month you born?" name="month"/>
                <textarea
                    name="personalStory"
                    cols="30"
                    rows="10"
                    placeholder="A personal story about yourself"
                    minlength="100"></textarea>
                <select name="meerkats" id="">
                    <option value="no">No i suck</option>
                    <option value="yes">Meerkats</option>
                </select>
                <button type="submit">SEND ZE INFO</button>
            </form>
            <form>
                <h3>GET BACK IN</h3>
                <input type="text" placeholder="Username" />
                <input type="password" placeholder="Password" />
                <button type="submit">HECK THE MATRIX</button>
            </form>
        </div>
        <div>
            <div>
                <h2>HAHA LOSER SIGN IN!</h2>
                <p>delicious personal information :3</p>
            </div>
            <button id="signupCloseButton">Close</button>
        </div>
    </div>
</div>

<style>
    button {
        width: 200px;
        aspect-ratio: 4/1;
        transition: transform 0.2s ease;
    }

    button:hover {
        animation: elasticPing 0.6s ease-out;
    }

    button:active {
        animation: elasticPing 0.6s ease-out;
    }

    @keyframes elasticPing {
        0% {
            transform: scale(1);
        }
        30% {
            transform: scale(1.15);
        }
        50% {
            transform: scale(0.95);
        }
        70% {
            transform: scale(1.05);
        }
        85% {
            transform: scale(0.98);
        }
        100% {
            transform: scale(1);
        }
    }

    #createLobby {
        position: absolute;
        left: 25%;
        rotate: -10deg;
    }

    #joinLobby {
        position: absolute;
        right: 25%;
        rotate: 10deg;
    }

    #signupForm {
        position: absolute;
        border: 5px solid black;
        border-radius: 20px;
        width: 50%;
        z-index: 1;
        left: 25%;
        top: 25%;
        background-color: white;
    }

    #signupForm > div {
        display: flex;
        flex-direction: row;
        gap: 15px;
        justify-content: space-between;
    }

    #signupForm form {
        display: flex;
        flex-direction: column;
        width: 100%;
    }

    #signupForm form > h3 {
        text-align: center;
    }

    textarea {
        resize: none;
    }
</style>

<script>
    let closeButton = document.getElementById(
        "signupCloseButton",
    ) as HTMLButtonElement;

    let makeAccount = document.getElementById("makeAccount") as HTMLFormElement;

    makeAccount.addEventListener("submit", (event) => {
        event.preventDefault();
        let formData = new FormData(makeAccount);

        formData.entries().forEach(elm => console.log(elm)
        );
    });

    closeButton.onclick = (event) => {
        let surroundElement = document.getElementById(
            "signupForm",
        ) as HTMLFormElement;
        surroundElement.hidden = true;
    };
</script>
